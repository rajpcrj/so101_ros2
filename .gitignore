# ROS 2 / colcon build artifacts — regenerated by `colcon build`
# (match at repo root AND nested, e.g. src/build/)
build/
install/
log/
.colcon/
COLCON_IGNORE

# Python
__pycache__/
*.py[cod]
*.egg-info/

# Editor / tooling local settings
/.claude/
/.vscode/

# OS junk
.DS_Store
*.swp

# NOTE: CAD/mesh assets (.step, .stl, .part) ARE tracked on purpose so a fresh
# clone + colcon build works without external downloads.
